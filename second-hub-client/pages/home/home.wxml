<view class="container">
  <view class="card search-box">
    <input class="search-input" placeholder="搜索商品" value="{{keyword}}" bindinput="onKeywordInput" />
    <button class="btn-primary" size="mini" bindtap="onSearch">搜索</button>
  </view>

  <block wx:for="{{goodsList}}" wx:key="id">
    <view class="card goods-item" data-id="{{item.id}}" bindtap="toDetail">
      <image class="cover" src="{{item.coverImage}}" mode="aspectFill" />
      <view class="right">
        <view class="title">{{item.title}}</view>
        <view class="desc">{{item.description}}</view>
        <view class="price">¥{{item.price}}</view>
      </view>
    </view>
  </block>

  <view class="footer">{{loading ? '加载中...' : (hasMore ? '上拉加载更多' : '没有更多了')}}</view>
</view>
