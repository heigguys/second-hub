<view class="container orders-page">
  <view class="panel">
    <view class="section-title">我的订单</view>
    <view class="segment">
      <view
        class="segment-item {{asRole === 'buyer' ? 'segment-item--active' : ''}}"
        data-role="buyer"
        bindtap="switchRole"
      >
        买家订单
      </view>
      <view
        class="segment-item {{asRole === 'seller' ? 'segment-item--active' : ''}}"
        data-role="seller"
        bindtap="switchRole"
      >
        卖家订单
      </view>
    </view>
  </view>

  <view wx:if="{{list.length > 0}}">
    <block wx:for="{{list}}" wx:key="id">
      <view class="panel order-card">
        <view class="order-head">
          <view class="order-no">订单号：{{item.orderNo}}</view>
          <view class="order-tags">
            <text class="tag {{item._orderStatusClass}}">{{item._orderStatusText}}</text>
            <text class="tag {{item._payStatusClass}}">{{item._payStatusText}}</text>
          </view>
        </view>
        <view class="order-title">{{item.goodsTitle}}</view>
        <view class="order-amount">金额：<text class="price-text">￥{{item.amount}}</text></view>

        <view class="actions">
          <button class="ghost-btn action-btn" size="mini" data-id="{{item.id}}" data-action="pay" bindtap="doAction">支付</button>
          <button class="ghost-btn action-btn" size="mini" data-id="{{item.id}}" data-action="buyerConfirm" bindtap="doAction">买家确认</button>
          <button class="ghost-btn action-btn" size="mini" data-id="{{item.id}}" data-action="sellerConfirm" bindtap="doAction">卖家确认</button>
          <button class="danger-btn action-btn" size="mini" data-id="{{item.id}}" data-action="cancel" bindtap="doAction">取消</button>
        </view>
      </view>
    </block>
  </view>

  <view class="panel empty-state" wx:else>
    <view class="empty-state-title">还没有订单</view>
    <view class="empty-state-desc">成交后会在这里查看订单状态</view>
  </view>
</view>
