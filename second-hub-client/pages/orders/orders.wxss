.orders-page {
  background: linear-gradient(180deg, #eef5ff 0%, #f4f7fc 220rpx);
}

.segment {
  margin-top: 18rpx;
  border-radius: 14rpx;
  padding: 8rpx;
  background: #f2f6fd;
  display: flex;
  gap: 8rpx;
}

.segment-item {
  flex: 1;
  height: 64rpx;
  border-radius: 10rpx;
  text-align: center;
  line-height: 64rpx;
  color: #6d7d95;
  font-size: 26rpx;
}

.segment-item--active {
  background: #ffffff;
  color: #2f7df6;
  font-weight: 600;
  box-shadow: 0 4rpx 10rpx rgba(35, 118, 235, 0.12);
}

.order-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.order-no {
  flex: 1;
  font-size: 24rpx;
  color: #7a879b;
  word-break: break-all;
}

.order-tags {
  display: flex;
  gap: 8rpx;
}

.order-title {
  margin-top: 14rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a2944;
}

.order-amount {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #5f7089;
}

.actions {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.action-btn {
  margin: 0;
  min-width: 150rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 24rpx;
  border-radius: 12rpx;
  padding: 0 18rpx;
}
