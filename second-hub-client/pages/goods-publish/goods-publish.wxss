.publish-page {
  background: linear-gradient(180deg, #eef5ff 0%, #f4f7fc 240rpx);
}

.upload-btn,
.submit-btn {
  width: 100%;
  padding: 0;
}

.upload-tip {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #8f9cb0;
}

.preview-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.preview-item {
  width: 100%;
  height: 200rpx;
  border-radius: 12rpx;
  background: #edf4ff;
}

.submit-btn {
  margin-top: 8rpx;
}
