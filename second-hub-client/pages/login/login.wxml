<view class="container login-page">
  <view class="panel hero-panel">
    <view class="login-icon">S</view>
    <view class="section-title">欢迎来到 Second Hub</view>
    <view class="section-subtitle">登录后即可发布闲置、收藏好物和管理订单</view>
  </view>

  <view class="panel">
    <view class="form-item">
      <text class="label-text">昵称</text>
      <input
        class="input-control"
        placeholder="请输入昵称"
        value="{{nickname}}"
        bindinput="onInput"
        disabled="{{loading}}"
      />
    </view>

    <button class="primary-btn login-btn" bindtap="login" loading="{{loading}}" disabled="{{loading}}">
      {{loading ? '登录中...' : '一键登录'}}
    </button>
  </view>
</view>
