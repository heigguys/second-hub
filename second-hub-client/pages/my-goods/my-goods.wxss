.my-goods-page {
  background: linear-gradient(180deg, #eef5ff 0%, #f4f7fc 200rpx);
}

.goods-card {
  display: flex;
  gap: 16rpx;
}

.goods-cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #edf4ff;
}

.goods-main {
  flex: 1;
  min-width: 0;
}

.goods-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 10rpx;
}

.goods-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 700;
  color: #1a2b45;
  word-break: break-all;
}

.goods-price {
  margin-top: 14rpx;
  color: #5f7089;
  font-size: 26rpx;
}

.actions {
  margin-top: 16rpx;
  display: flex;
  gap: 10rpx;
}

.action-btn {
  margin: 0;
  height: 62rpx;
  line-height: 62rpx;
  font-size: 24rpx;
  border-radius: 12rpx;
  min-width: 120rpx;
  padding: 0 20rpx;
}
