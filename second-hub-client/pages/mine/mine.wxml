<view class="container mine-page">
  <view class="panel profile-panel">
    <view class="avatar">{{token ? nicknameInitial : '未'}}</view>
    <view class="profile-main">
      <view class="profile-name">{{token ? (userInfo.nickname || '微信用户') : '未登录'}}</view>
      <view class="profile-tip">
        {{token ? '欢迎回来，看看今天有什么新发布' : '登录后可同步收藏、发布和订单数据'}}
      </view>
    </view>
  </view>

  <view class="panel" wx:if="{{!token}}">
    <view class="empty-state login-empty">
      <view class="empty-state-title">还没有登录账号</view>
      <view class="empty-state-desc">点击下方按钮即可完成微信登录</view>
    </view>
    <button class="primary-btn" bindtap="toLogin">微信一键登录</button>
  </view>

  <view wx:else>
    <view class="panel menu-panel">
      <view class="menu-item" bindtap="toFavorites">
        <text class="menu-text">我的收藏</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-divider"></view>
      <view class="menu-item" bindtap="toMyGoods">
        <text class="menu-text">我的发布</text>
        <text class="menu-arrow">></text>
      </view>
    </view>

    <view class="panel">
      <button class="danger-btn" bindtap="logout">退出登录</button>
    </view>
  </view>
</view>
