.cover {
  width: 100%;
  height: 420rpx;
  border-radius: 12rpx;
}

.title {
  margin-top: 16rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.price {
  margin-top: 10rpx;
  color: #f56c6c;
  font-size: 36rpx;
}

.desc {
  margin-top: 14rpx;
  color: #606266;
}

.seller {
  margin-top: 8rpx;
  color: #909399;
}

.action-row {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
}

.sub-title {
  font-weight: 600;
  margin-bottom: 14rpx;
}

.comment-input-row {
  display: flex;
  gap: 10rpx;
}

.comment-input {
  flex: 1;
  border: 1px solid #dcdfe6;
  border-radius: 10rpx;
  height: 64rpx;
  padding: 0 16rpx;
}

.comment-item {
  border-top: 1px solid #f0f0f0;
  margin-top: 12rpx;
  padding-top: 12rpx;
}

.comment-user {
  color: #409eff;
  margin-bottom: 4rpx;
}
