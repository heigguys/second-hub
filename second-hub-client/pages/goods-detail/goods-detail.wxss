.detail-page {
  background: linear-gradient(180deg, #eef5ff 0%, #f4f7fc 260rpx);
}

.detail-cover {
  width: 100%;
  height: 440rpx;
  border-radius: 16rpx;
  background: #edf4ff;
}

.detail-title {
  margin-top: 18rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #17253d;
  line-height: 1.4;
}

.detail-price-row {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.detail-desc {
  margin-top: 16rpx;
  color: #637591;
  line-height: 1.75;
  white-space: pre-wrap;
}

.detail-seller {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8a97ab;
}

.action-row {
  margin-top: 24rpx;
  display: flex;
  gap: 12rpx;
}

.action-btn {
  flex: 1;
  margin: 0;
  padding: 0;
}

.comment-title {
  font-size: 30rpx;
}

.comment-input-row {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.comment-input {
  flex: 1;
}

.comment-btn {
  width: 132rpx;
  margin: 0;
  padding: 0;
}

.comment-item {
  margin-top: 18rpx;
  border-top: 1px solid #edf2fa;
  padding-top: 16rpx;
}

.comment-user {
  font-size: 24rpx;
  color: #2f7df6;
  font-weight: 600;
}

.comment-content {
  margin-top: 8rpx;
  color: #455972;
  line-height: 1.7;
}

.comment-empty {
  margin-top: 8rpx;
  padding: 24rpx 0 8rpx;
}
